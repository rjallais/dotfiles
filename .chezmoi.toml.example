# Example Chezmoi data configuration
# Copy this to ~/.config/chezmoi/chezmoi.toml to customize

[data]
    name = "Your Name"
    git_email_default = "commits@example.com"

[edit]
    command = "vim"
    # Other options: "code", "nano", "emacs"

[diff]
    pager = "delta"
    # Other options: "less", "more", "bat"

# Per-host Git overrides live in:
# - dot_gitconfig.github
# - dot_gitconfig.gitlab
# - dot_gitconfig.codefloe
